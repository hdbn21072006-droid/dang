{
  "name": "student-management-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for Student Management System",
  "main": "dist-backend/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.backend.json",
    "start": "node dist-backend/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --project tsconfig.backend.json src/backend/index.ts",
    "migrate": "ts-node-dev --transpile-only --project tsconfig.backend.json src/backend/database/migrate.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.7",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.0",
    "@types/nodemailer": "^6.4.17",
    "@types/nodemailer": "^6.4.17",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
